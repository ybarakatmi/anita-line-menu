NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Optional: public MP4 URLs (e.g. Supabase Storage) for homepage hero / separator when DB fields are empty.
# Must be H.264 MP4; autoplay is muted+inline — works on iOS Safari and Chrome. DB site_settings overrides these.
# NEXT_PUBLIC_HERO_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/hero.mp4
# NEXT_PUBLIC_SEPARATOR_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/separator.mp4

# Used for server-only team invites (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: canonical site URL for invite redirect links (defaults to VERCEL_URL or localhost)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
