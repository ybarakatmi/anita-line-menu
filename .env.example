NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Optional: override bundled `/public/hero.mp4` for hero and separator strip when DB fields are empty (same file by default).
# Upload to Storage: `npm run upload-hero -- /path/to/hero.mp4` (needs SUPABASE_SERVICE_ROLE_KEY in .env.local).
# NEXT_PUBLIC_HERO_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/custom-hero.mp4
# Optional hero video poster (see site_settings / Admin when DB is used).
# NEXT_PUBLIC_HERO_VIDEO_POSTER_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/hero-poster.jpg
# NEXT_PUBLIC_SEPARATOR_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/separator.mp4

# Used for server-only team invites (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBsZHJheGhzaXFmbHdkandjaWpwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NzM1MDUxMSwiZXhwIjoyMDkyOTI2NTExfQ.nZiYpBURAqrGOYK6UjPOL2JHCK_t20ataFx8ne3eC60

