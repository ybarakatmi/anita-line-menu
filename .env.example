NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Optional: override hero / separator MP4 when DB fields are empty. Otherwise the app uses the conventional
# public object: {NEXT_PUBLIC_SUPABASE_URL}/storage/v1/object/public/menu-images/hero.mp4 (upload via
# `npm run upload-hero -- /path/to/hero.mp4` with SUPABASE_SERVICE_ROLE_KEY set). Must be H.264; autoplay is muted+inline.
# NEXT_PUBLIC_HERO_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/custom-hero.mp4
# NEXT_PUBLIC_SEPARATOR_VIDEO_URL=https://xxxx.supabase.co/storage/v1/object/public/menu-images/separator.mp4

# Used for server-only team invites (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: canonical site URL for invite redirect links (defaults to VERCEL_URL or localhost)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
